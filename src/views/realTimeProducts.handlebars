<h1>Productos en tiempo real</h1>
<ul id="productsList">
  {{#each products}}
    <li data-id="{{this.id}}">
      {{this.title}} - ${{this.price}}
      <button class="deleteBtn" data-id="{{this.id}}">Eliminar</button>
    </li>
  {{/each}}
</ul>

<h2>Añadir producto</h2>
<form id="productForm">
  <input name="title" placeholder="title" required />
  <input name="description" placeholder="description" required />
  <input name="code" placeholder="code" required />
  <input name="price" type="number" placeholder="price" required />
  <input name="stock" type="number" placeholder="stock" required />
  <button type="submit">Agregar</button>
</form>

<script>
  const socket = io();

  socket.on('connect', () => {
    console.log('Conectado al servidor de sockets');
  });

  socket.on('productsUpdated', (products) => {
    const list = document.getElementById('productsList');
    list.innerHTML = '';
    products.forEach(p => {
      const li = document.createElement('li');
      li.dataset.id = p.id;
      li.textContent = `${p.title} - $${p.price}`;
      const btn = document.createElement('button');
      btn.textContent = 'Eliminar';
      btn.className = 'deleteBtn';
      btn.dataset.id = p.id;
      li.appendChild(btn);
      list.appendChild(li);
    });
  });

  document.getElementById('productForm').addEventListener('submit', e => {
    e.preventDefault();
    const data = {
      title: e.target.title.value,
      description: e.target.description.value,
      code: e.target.code.value,
      price: parseFloat(e.target.price.value),
      stock: parseInt(e.target.stock.value, 10)
    };
    socket.emit('createProduct', data);
    e.target.reset();
  });

  document.getElementById('productsList').addEventListener('click', e => {
    if (e.target.classList.contains('deleteBtn')) {
      const id = e.target.dataset.id;
      socket.emit('deleteProduct', parseInt(id,10));
    }
  });
</script>